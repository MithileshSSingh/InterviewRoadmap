// This is your Prisma schema file
// Prisma v6 — output goes to src/generated/prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── NextAuth.js v5 models ───────────────────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  roadmaps          Roadmap[]
  bookmarks         Bookmark[]
  comparisons       Comparison[]
  interviewSessions InterviewSession[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application models ─────────────────────────────────────────────────────

model Roadmap {
  id              String          @id @default(cuid())
  sessionId       String
  userId          String?
  role            String
  company         String
  experienceLevel String
  status          String          @default("pending") // pending | running | complete | error
  result          String? // Full canonical JSON (stringified)
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  topicProgress   TopicProgress[]
  agentRuns       AgentRun[]
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@map("roadmaps")
}

model TopicProgress {
  id          String    @id @default(cuid())
  roadmapId   String
  topicId     String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, topicId])
  @@map("topic_progress")
}

model AgentRun {
  id           String    @id @default(cuid())
  roadmapId    String
  agentName    String
  status       String    @default("pending") // pending | running | complete | error
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  roadmap      Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@map("agent_runs")
}

// ─── Bookmarks ───────────────────────────────────────────────────────────────

model Bookmark {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String
  slug         String
  phaseId      String
  topicId      String
  topicTitle   String
  phaseTitle   String
  roadmapTitle String
  roadmapEmoji String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, slug, phaseId, topicId])
  @@index([sessionId])
  @@index([userId])
  @@map("bookmarks")
}

// ─── Comparative Intelligence ────────────────────────────────────────────────

model Comparison {
  id                String               @id @default(cuid())
  sessionId         String
  userId            String?
  mode              String
  status            String               @default("pending")
  title             String
  summary           String?
  priority          String?
  location          String?
  experienceLevel   String?
  currentRole       String?
  yearsOfExperience Int?
  visibility        String               @default("private")
  shareToken        String?              @unique
  result            String?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  lastRefreshedAt   DateTime?
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  targets           ComparisonTarget[]
  runs              ComparisonRun[]
  snapshots         ComparisonSnapshot[]
  sources           ComparisonSource[]

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@map("comparisons")
}

model ComparisonTarget {
  id                String           @id @default(cuid())
  comparisonId      String
  side              String
  targetType        String
  role              String?
  company           String?
  label             String
  normalizedRole    String?
  normalizedCompany String?
  location          String?
  experienceLevel   String?
  inputPayload      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  comparison        Comparison       @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  sources           ComparisonSource[]

  @@unique([comparisonId, side])
  @@index([comparisonId])
  @@map("comparison_targets")
}

model ComparisonRun {
  id           String     @id @default(cuid())
  comparisonId String
  runType      String     @default("initial")
  status       String     @default("pending")
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  log          String?
  createdAt    DateTime   @default(now())
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@index([comparisonId])
  @@map("comparison_runs")
}

model ComparisonSnapshot {
  id           String     @id @default(cuid())
  comparisonId String
  version      Int        @default(1)
  payload      String
  createdAt    DateTime   @default(now())
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@index([comparisonId])
  @@map("comparison_snapshots")
}

model ComparisonSource {
  id             String           @id @default(cuid())
  comparisonId   String
  targetId       String?
  dimensionKey   String?
  title          String
  url            String
  domain         String?
  sourceType     String?
  publishedAt    DateTime?
  accessedAt     DateTime         @default(now())
  trustScore     Int?
  freshnessScore Int?
  notes          String?
  comparison     Comparison       @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  target         ComparisonTarget? @relation(fields: [targetId], references: [id], onDelete: SetNull)

  @@index([comparisonId])
  @@index([targetId])
  @@map("comparison_sources")
}

// ─── Mock Interview ──────────────────────────────────────────────────────────

model InterviewSession {
  id          String    @id @default(cuid())
  topicId     String
  topicTitle  String
  roadmapSlug String
  phaseId     String
  mode        String    // "guided" | "freeform"
  score       Float?    // 0–10 average for guided; null for freeform
  summary     String?   // AI final feedback text
  messages    String    // JSON-stringified array
  sessionId   String    // always present (generated client-side if needed)
  userId      String?   // set when authenticated
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@map("interview_sessions")
}

// ─── Feedback ────────────────────────────────────────────────────────────────

model Feedback {
  id          String   @id @default(cuid())
  type        String   // "bug" | "feature" | "content" | "general"
  category    String?
  message     String
  email       String?
  rating      Int?     // 1-5
  roadmapSlug String?
  phaseId     String?
  topicId     String?
  pagePath    String?
  metadata    String?  // JSON-stringified browser/app context
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feedback")
}
