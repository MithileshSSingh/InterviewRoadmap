// This is your Prisma schema file
// Prisma v6 — output goes to src/generated/prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── NextAuth.js v5 models ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  roadmaps      Roadmap[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application models ─────────────────────────────────────────────────────

model Roadmap {
  id              String          @id @default(cuid())
  sessionId       String
  userId          String?
  role            String
  company         String
  experienceLevel String
  status          String          @default("pending") // pending | running | complete | error
  result          String? // Full canonical JSON (stringified)
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  topicProgress   TopicProgress[]
  agentRuns       AgentRun[]
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@map("roadmaps")
}

model TopicProgress {
  id          String    @id @default(cuid())
  roadmapId   String
  topicId     String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@unique([roadmapId, topicId])
  @@map("topic_progress")
}

model AgentRun {
  id           String    @id @default(cuid())
  roadmapId    String
  agentName    String
  status       String    @default("pending") // pending | running | complete | error
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  roadmap      Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@map("agent_runs")
}

// ─── Feedback ────────────────────────────────────────────────────────────────

model Feedback {
  id          String   @id @default(cuid())
  type        String   // "bug" | "feature" | "content" | "general"
  category    String?
  message     String
  email       String?
  rating      Int?     // 1-5
  roadmapSlug String?
  phaseId     String?
  topicId     String?
  pagePath    String?
  metadata    String?  // JSON-stringified browser/app context
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feedback")
}
